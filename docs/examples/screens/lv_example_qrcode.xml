<!--
 @title QR code
 @brief Two QR codes with custom colours, size and quiet zone.

 `data` is the encoded UTF-8 string and `size` sets the square side in
 pixels. `dark_color`/`light_color` recolour the modules and background,
 and `quiet_zone="true"` adds the recommended margin so scanners read it
 reliably.
-->
<screen>
	<view flex_flow="column" style_pad_row="14" style_pad_all="14"
		style_flex_cross_place="center">

		<!-- 💡 Both encode the same URL; only size and colours differ. -->
		<lv_label width="100%" style_text_align="center" text="QR code: colours and size" />

		<lv_obj width="290" height="150" style_bg_opa="0" style_pad_all="0"
			flex_flow="row" style_flex_main_place="space_evenly"
			style_flex_cross_place="center">

			<lv_qrcode size="120"
				dark_color="0x1f2937" light_color="0xffffff"
				quiet_zone="true" data="https://lvgl.io" />

			<lv_qrcode size="100"
				dark_color="0x2563eb" light_color="0xeff6ff"
				quiet_zone="true" data="https://lvgl.io" />
		</lv_obj>
	</view>
</screen>
