<!--
 @title Checkbox
 @brief Default, checked and disabled checkboxes, plus a bound pair.

 Each checkbox gets its caption from the `text` property. The first starts
 `checked="true"`, the second is `disabled="true"`. The last two share
 `bind_checked="subject_checked"`, so ticking one ticks the other.
-->
<screen>
	<styles>
		<!-- Recolour the tick box (the INDICATOR part) when checked -->
		<style name="style_tick_checked"
			bg_color="0x16a34a" border_color="0x16a34a" />
	</styles>

	<view flex_flow="column" style_pad_row="14" style_pad_all="18">

		<!-- 💡 Tick either bound checkbox — both follow subject_checked. -->
		<lv_label width="100%" style_text_align="center" text="Checkbox: states and binding" />

		<!-- Checked by default -->
		<lv_checkbox text="Enable feature" checked="true">
			<style name="style_tick_checked" selector="checked|indicator" />
		</lv_checkbox>

		<!-- Disabled -->
		<lv_checkbox text="Unavailable option" disabled="true" />

		<!-- Two checkboxes bound to the same subject -->
		<lv_checkbox text="Sync A" bind_checked="subject_checked">
			<style name="style_tick_checked" selector="checked|indicator" />
		</lv_checkbox>
		<lv_checkbox text="Sync B" bind_checked="subject_checked">
			<style name="style_tick_checked" selector="checked|indicator" />
		</lv_checkbox>
	</view>
</screen>
