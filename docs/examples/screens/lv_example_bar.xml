<!--
 @title Bar
 @brief Normal, symmetrical and range modes, plus a subject-bound bar.

 The first bar is bound to `subject_value`. The second uses
 `mode="symmetrical"` with a range crossing zero so the indicator grows out
 from the midpoint. The third uses `mode="range"` with a `start_value` and
 `value` to show a span, and the last is vertical.
-->
<screen>
	<styles>
		<style name="style_bar" bg_color="0xe2e8f0" bg_opa="100%" radius="6" />
		<style name="style_bar_ind" bg_color="0x3b82f6" radius="6" />
	</styles>

	<view flex_flow="column" style_pad_row="14" style_pad_all="16"
		style_flex_cross_place="center">

		<!-- 💡 The first bar follows subject_value; the readout sits on top of it. -->
		<lv_label width="100%" style_text_align="center" text="Bar: modes and binding" />

		<!-- Bound, normal mode, with an overlaid readout -->
		<lv_bar width="240" height="22" bind_value="subject_value">
			<style name="style_bar" />
			<style name="style_bar_ind" selector="indicator" />
			<lv_label align="center" bind_text="subject_value"
				bind_text-fmt="%d %%" style_text_color="#color_text_on_fill" />
		</lv_bar>

		<!-- Symmetrical: grows from the midpoint of a signed range -->
		<lv_bar width="240" height="18" mode="symmetrical"
			min_value="-100" max_value="100" value="-40">
			<style name="style_bar" />
			<style name="style_bar_ind" selector="indicator" />
		</lv_bar>

		<!-- Range: indicator spans start_value..value -->
		<lv_bar width="240" height="18" mode="range"
			start_value="30" value="80">
			<style name="style_bar" />
			<style name="style_bar_ind" selector="indicator" />
		</lv_bar>

		<!-- Vertical orientation -->
		<lv_bar width="18" height="80" orientation="vertical" value="65">
			<style name="style_bar" />
			<style name="style_bar_ind" selector="indicator" />
		</lv_bar>
	</view>
</screen>
