<!--
 @title Image button
 @brief A button drawn from per-state images instead of a styled rectangle.

 `<lv_imagebutton-src_left>`, `-src_mid` and `-src_right` set the image for
 a given `state`. The middle image is tiled to fill the width, so left and
 right act as fixed end-caps. Here the released and pressed states use the
 same source to keep the example self-contained.
-->
<screen>
	<view flex_flow="column" style_pad_row="14" style_pad_all="18"
		style_flex_cross_place="center">

		<!-- 💡 Press the button — image buttons swap their source per state. -->
		<lv_label width="100%" style_text_align="center" text="Image button: per-state images" />

		<lv_imagebutton width="160" height="48">
			<!-- End caps + tiled middle, for the released state -->
			<lv_imagebutton-src_left  state="released" src="img_logo" />
			<lv_imagebutton-src_mid   state="released" src="img_logo" />
			<lv_imagebutton-src_right state="released" src="img_logo" />
			<!-- Same images while pressed -->
			<lv_imagebutton-src_left  state="pressed"  src="img_logo" />
			<lv_imagebutton-src_mid   state="pressed"  src="img_logo" />
			<lv_imagebutton-src_right state="pressed"  src="img_logo" />

			<lv_label align="center" text="Press" style_text_color="0xffffff" />
		</lv_imagebutton>
	</view>
</screen>
