<!--
 @title Canvas
 @brief Reserve a Canvas in XML; its draw buffer is supplied from C.

 Canvas has no XML-settable properties: it needs a pixel buffer assigned
 at runtime with lv_canvas_set_buffer(), after which the C code draws into
 it. The XML side just lays out and sizes the widget; everything visible is
 produced by the application's drawing calls.
-->
<screen>
	<styles>
		<style name="style_canvas"
			bg_color="0x0f172a" bg_opa="100%" radius="8"
			border_color="0x3b82f6" border_width="1" />
	</styles>

	<view flex_flow="column" style_pad_row="12" style_pad_all="16"
		style_flex_cross_place="center">

		<!-- 💡 The framed box is the Canvas; assign its buffer in C to draw into it. -->
		<lv_label width="100%" style_text_align="center" text="Canvas: buffer set from C" />

		<lv_canvas width="180" height="120">
			<style name="style_canvas" />
		</lv_canvas>
	</view>
</screen>
